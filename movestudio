#!/bin/bash

SOURCE_DIR="$HOME/Desktop/Local_recordings"
DEST_DIR="/Volumes/TElements/Studio"
LOCKFILE="/tmp/move_recordings.lock"
LOGDIR="$HOME/Library/Logs/move_recordings"
LOG_RETENTION_DAYS=30
IDLE_MINUTES=1

FILES_MOVED=false
FILES_WAITING=false
MOVED_FILES=()
LINECUT_FILES=()
MULTIVIEW_FILES=()
RSINGESTMANIFEST="$(command -v rsingestmanifest.py)"

echo "Using rsingestmanifest: $RSINGESTMANIFEST"

if [ -z "$RSINGESTMANIFEST" ]; then
    echo "rsingestmanifest.py not found in PATH"
    exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 not found in PATH"
    exit 1
fi

mkdir -p "$LOGDIR"

get_logfile() {
    echo "$LOGDIR/move_failures_$(date '+%Y-%m-%d').log"
}

log_failure() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') | Failed: $1" >> "$(get_logfile)"
}

cleanup_logs() {
    find "$LOGDIR" -type f -name "move_failures_*.log" -mtime +$LOG_RETENTION_DAYS -exec rm {} \;
}

is_idle() {
    local file="$1"
    [ -f "$file" ] || return 1
    find "$file" -maxdepth 0 -mmin +$IDLE_MINUTES | grep -q .
}

TEST_MODE=false
if [[ "$1" == "--test" ]]; then
    TEST_MODE=true
    echo "Running in TEST MODE — no files will be moved."
fi

if ! $TEST_MODE; then
    if [ -e "$LOCKFILE" ] && kill -0 "$(cat "$LOCKFILE")" 2>/dev/null; then
        exit 0
    fi

    echo $$ > "$LOCKFILE"
    trap 'rm -f "$LOCKFILE"' EXIT
fi

if ! $TEST_MODE && [ ! -d "$DEST_DIR" ]; then
    exit 0
fi

if ! $TEST_MODE; then
    cleanup_logs
fi

##remove_sdtb
while read -r FILE; do

    echo "Running remove_sdtb: $FILE"

    if is_idle "$FILE"; then

        if command -v remove_sdtb >/dev/null 2>&1; then
            if ! remove_sdtb "$FILE"; then
                echo "remove_sdtb failed on: $FILE" >&2
                log_failure "$FILE"
                continue
            fi
        else
            echo "Warning: remove_sdtb not found in PATH" >&2
        fi

    else
        echo "Still writing: $FILE"
        FILES_WAITING=true
    fi

done < <(find "$SOURCE_DIR" -type f -iname "*.mov")

echo "Bear with me. I'm just waiting for files to become idle before proceeding."
sleep 70

##rsync files to the server

while read -r FILE; do

    echo "MOVING FILE: $FILE"

    if is_idle "$FILE"; then

        REL_PATH="${FILE#$SOURCE_DIR/}"
        DEST_PATH="$DEST_DIR/$(dirname "$REL_PATH")"

        if $TEST_MODE; then
            echo "Would move: $FILE → $DEST_PATH/"
        else
            mkdir -p "$DEST_PATH"

            echo "Moving: $FILE → $DEST_PATH/"

            if rsync -rtvP --remove-source-files "$FILE" "$DEST_PATH/" 2>/dev/null; then
                FILES_MOVED=true
                DEST_FILE="$DEST_PATH/$(basename "$FILE")"
                MOVED_FILES+=("$DEST_FILE")
                BASENAME="$(basename "$FILE")"

                if [[ "${BASENAME}" == *Line*Cut* ]]; then
                    LINECUT_FILES+=("$DEST_FILE")
                fi

            else
                log_failure "$FILE"
            fi
        fi

    else
        echo "Still writing: $FILE"
        FILES_WAITING=true
    fi

done < <(find "$SOURCE_DIR" -type f \( -iname "*.mov" -o -iname "*.mp4" \))

## create rs manifest

for FOLDER in $(printf '%s\n' "${LINECUT_FILES[@]}" | xargs -n1 dirname | sort -u); do

    FILES=()

    for FILE in "${LINECUT_FILES[@]}"; do
        if [[ "$(dirname "$FILE")" == "$FOLDER" ]]; then
            FILES+=("$FILE")
        fi
    done

    if [ ${#FILES[@]} -gt 0 ]; then

        echo "Creating Line Cut manifest for: $FOLDER"
        printf '  %s\n' "${FILES[@]}"

        if ! $TEST_MODE; then
            python3 "$RSINGESTMANIFEST" \
                --type studio \
                --folder "$FOLDER" \
                --files "${FILES[@]}"
        fi
    fi
done

##run makestudio

for FILE in "${LINECUT_FILES[@]}"; do

        if command -v makestudio >/dev/null 2>&1; then
            if $TEST_MODE; then
                echo "Would run makestudio on: $FILE"
            else
                echo "Running makestudio on: $FILE"
                makestudio "$FILE"
                
                LINECUT_DIR="$(dirname "$FILE")"
                PARENT_DIR="$(dirname "$LINECUT_DIR")"
                LINECUT_FOLDER="$(basename "$LINECUT_DIR")"
                SHOW_NAME="${LINECUT_FOLDER%_Line_Cut}"
                SHOW_NAME="${SHOW_NAME%_LINE_CUT}"
                TIMESTAMP="$(basename "$FILE")"
                TIMESTAMP="${TIMESTAMP%% *}"
                MULTIVIEW_FILE="${PARENT_DIR}/${SHOW_NAME}_MULTIVIEWS/${TIMESTAMP}_${SHOW_NAME}_MULTIVIEW.mp4"

                if [ -f "$MULTIVIEW_FILE" ]; then
                    echo "Found multiview: $MULTIVIEW_FILE"
                    MULTIVIEW_FILES+=("$MULTIVIEW_FILE")
                else
                    echo "Expected multiview not found: $MULTIVIEW_FILE"
                fi
            fi
        else
            echo "Warning: makestudio not found in PATH" >&2
            log_failure "$FILE (makestudio not found)"
        fi
done

##multiview manifest

for FOLDER in $(printf '%s\n' "${MULTIVIEW_FILES[@]}" | xargs -n1 dirname | sort -u); do

    FILES=()

    for FILE in "${MULTIVIEW_FILES[@]}"; do

        if [[ "$(dirname "$FILE")" == "$FOLDER" ]]; then
            FILES+=("$FILE")
        fi

    done

    if [ ${#FILES[@]} -gt 0 ]; then

        echo "Creating Multiview manifest for: $FOLDER"
        printf '  %s\n' "${FILES[@]}"

        if $TEST_MODE; then

            echo "Would run:"
            echo "python3 $RSINGESTMANIFEST --type studio --folder \"$FOLDER\" --files ..."

        else

            python3 "$RSINGESTMANIFEST" \
                --type studio \
                --folder "$FOLDER" \
                --files "${FILES[@]}"

        fi

    fi

done


if $FILES_MOVED && [ -t 1 ]; then
cat <<'EOF'

====================================================
 🎉  Transfer and Multiview File Creation Complete!
====================================================

EOF
fi

if ! $FILES_MOVED && $FILES_WAITING && [ -t 1 ]; then
cat <<'EOF'

Some recordings are still in progress.

If files were just recorded, wait a couple minutes
and run the script again.

EOF
fi